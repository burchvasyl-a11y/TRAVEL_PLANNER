<Window x:Class="TRAVEL_PLANNER.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TRAVEL PLANNER"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindowStyle}">
    <Border Background="{DynamicResource PageOverlayBrush}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="TRAVEL PLANNER"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button Content="Головна"
                            Style="{StaticResource NavButtonStyle}"
                            FontWeight="Bold"
                            Click="Main_Click"/>
                        <Button Content="Країни"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Countries_Click"/>
                        <Button Content="Міста"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Cities_Click"/>
                        <Button Content="Налаштування"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Settings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center"
                        Margin="0,0,30,0">
                    <TextBlock Text="Плануйте мандрівки в одному місці"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="34"/>

                    <Border Margin="0,28,0,0"
                        Height="340"
                        CornerRadius="28"
                        Background="{StaticResource PrimaryBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Margin="28"
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Text="Створюйте маршрути, підбирайте місця, обирайте темну або світлу тему й зберігайте майбутні подорожі"/>
                            <TextBlock Grid.Row="1"
                                   Margin="28"
                                   Foreground="#CCFFFFFF"
                                   FontSize="16"
                                   Text="Країни, карти, фільтри, збереження подорожей і швидкий перехід між сторінками"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="32"
                    VerticalAlignment="Center"
                    MaxWidth="460">
                    <StackPanel>
                        <TextBlock Text="Вхід"
                               Style="{StaticResource TitleTextStyle}"
                               FontSize="30"/>
                        <TextBlock Text="Увійдіть, щоб переглядати й додавати свої подорожі"
                               Style="{StaticResource SubtitleTextStyle}"
                               Margin="0,10,0,0"/>

                        <TextBlock x:Name="EmailLabel"
                               Margin="0,24,0,0"
                               FontWeight="SemiBold"
                               Text="Введіть адресу ел. пошти:"/>
                        <TextBox x:Name="EmailTextBox"
                             Style="{StaticResource InputTextBoxStyle}"/>

                        <TextBlock x:Name="PasswordLabel"
                               Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Введіть пароль:"/>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource InputPasswordBoxStyle}"/>
                            <TextBox x:Name="PasswordTextBox"
                                 Visibility="Collapsed"
                                 Style="{StaticResource InputTextBoxStyle}"/>
                            <Image
                                   Source="/TRAVEL_PLANNER;component/Resources/Icons/eye.ico"
                                   MouseLeftButtonUp="TogglePassword_Click" Margin="366,11,10,5"/>
                        </Grid>

                        <TextBlock x:Name="ForgotLabel"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextDecorations="Underline"
                               Cursor="Hand"
                               MouseLeftButtonUp="ForgotPassword_Click"
                               Text="Забули пароль?"/>

                        <Button x:Name="LoginButton"
                            Margin="0,24,0,0"
                            Height="46"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="LoginButton_Click"
                            Content="Ввійти"/>

                        <Button x:Name="GoogleButton"
                            Margin="0,16,0,0"
                            Height="46"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="GoogleButton_Click">
                            <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                                <Image Width="18"
                                   Height="18"
                                   Margin="0,0,10,0"
                                   Source="/TRAVEL_PLANNER;component/Resources/Icons/google.ico"/>
                                <TextBlock VerticalAlignment="Center"
                                       Text="Вхід через Google"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="GitHubButton"
                            Margin="0,10,0,0"
                            Height="46"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="GitHubButton_Click">
                            <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                                <Image Width="18"
                                   Height="18"
                                   Margin="0,0,10,0"
                                   Source="/TRAVEL_PLANNER;component/Resources/Icons/github.ico"/>
                                <TextBlock VerticalAlignment="Center"
                                       Text="Вхід через GitHub"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
