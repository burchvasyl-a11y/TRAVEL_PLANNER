<Window x:Class="TRAVEL_PLANNER.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TRAVEL_PLANNER.Models"
        Title="TRAVEL PLANNER"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindowStyle}">
    <Border Background="{DynamicResource PageOverlayBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="TRAVEL PLANNER"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button Content="Головна"
                            Style="{StaticResource NavButtonStyle}"
                            FontWeight="Bold"
                            Click="Main_Click"/>
                    <Button Content="Країни"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Countries_Click"/>
                    <Button Content="Міста"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Cities_Click"/>
                    <Button Content="Налаштування"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Settings_Click"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#CCFFFFFF"
                           Text="{Binding UserEmailText}"/>
            </Grid>
        </Border>

        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                    <TextBlock Text="Головна"
                           Style="{StaticResource TitleTextStyle}"
                           FontSize="34"/>
                </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,24,0,0">
                <Border x:Name="EmptyStateBorder"
                        Style="{StaticResource CardBorderStyle}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch">
                    <TextBlock x:Name="EmptyStateText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="Ще немає збережених подорожей"/>
                </Border>

                <ScrollViewer x:Name="TripsScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <ItemsControl x:Name="TripsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}"
                                        Margin="0,0,0,18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontSize="30"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CountryName}"/>
                                            <TextBlock Margin="0,12,0,0"
                                                       FontSize="16"
                                                       Text="{Binding DisplayDateRange}"/>
                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding PrimaryCategory}"/>
                                                <TextBlock FontSize="16"
                                                           Text="{Binding SecondaryCategory}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button x:Name="DetailesButton"
                                                Grid.Column="1"
                                                Width="140"
                                                Height="44"
                                                VerticalAlignment="Bottom"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="Details_Click"
                                                Tag="{Binding}"
                                                Content="Детальніше..."/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Button x:Name="AddButton"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Width="170"
                    Height="48"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="AddTrip_Click"
                    Content="+    Додати"/>
        </Grid>
    </DockPanel>
    </Border>
</Window>
