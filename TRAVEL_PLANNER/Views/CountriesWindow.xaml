<Window x:Class="TRAVEL_PLANNER.Views.CountriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TRAVEL_PLANNER.Models"
        Title="TRAVEL PLANNER"
        Width="1380"
        Height="860"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindowStyle}">
    <Border Background="{DynamicResource PageOverlayBrush}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="TRAVEL PLANNER"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <Button Content="Головна"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Main_Click"/>
                        <Button Content="Країни"
                            Style="{StaticResource NavButtonStyle}"
                            FontWeight="Bold"
                            Click="Countries_Click"/>
                        <Button Content="Міста"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Cities_Click"/>
                        <Button Content="Налаштування"
                            Style="{StaticResource NavButtonStyle}"
                            Click="Settings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Країни"
                                       Style="{StaticResource TitleTextStyle}"
                                       FontSize="28"/>

                                <TextBlock x:Name="EnterNameLabel"
                                       Margin="0,22,0,0"
                                       FontWeight="SemiBold"
                                       Text="Введіть назву країни:"/>
                                <TextBox x:Name="TextBox_Country"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     TextChanged="CountryTextBox_TextChanged"/>

                                <TextBlock x:Name="TimeLabel"
                                       Margin="0,18,0,0"
                                       FontWeight="SemiBold"
                                       Text="Тривалість подорожі"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock x:Name="Lbl1"
                                               Margin="0,10,0,0"
                                               Text="Від:"/>
                                        <DatePicker x:Name="DatePickerFrom"
                                                Style="{StaticResource DatePickerStyle}"
                                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="Lbl2"
                                               Margin="0,10,0,0"
                                               Text="До:"/>
                                        <DatePicker x:Name="DatePickerTo"
                                                Style="{StaticResource DatePickerStyle}"
                                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="LabelSpecific"
                                       Margin="0,18,0,0"
                                       FontWeight="SemiBold"
                                       Text="Вид подорожі"/>
                                <CheckBox x:Name="CheckBoxSea"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Content="Відпочинок на морі"
                                      Checked="Filters_Changed"
                                      Unchecked="Filters_Changed"/>
                                <CheckBox x:Name="CheckBoxNature"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Content="Відпочинок на природі"
                                      Checked="Filters_Changed"
                                      Unchecked="Filters_Changed"/>
                                <CheckBox x:Name="CheckBoxActivities"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Content="Активний туризм"
                                      Checked="Filters_Changed"
                                      Unchecked="Filters_Changed"/>
                                <CheckBox x:Name="CheckBoxHistoric"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Content="Історичні пам'ятки"
                                      Checked="Filters_Changed"
                                      Unchecked="Filters_Changed"/>
                                <CheckBox x:Name="CheckBoxShopping"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Content="Шоп-тур + гастрономія"
                                      Checked="Filters_Changed"
                                      Unchecked="Filters_Changed"/>

                                <TextBlock Margin="0,22,0,0"
                                       FontWeight="SemiBold"
                                       Text="ОСНОВНА ІНФОРМАЦІЯ"/>
                                <TextBox x:Name="TextBox_Info"
                                     Height="170"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource InputTextBoxStyle}"/>

                                <Button x:Name="SaveButton"
                                    Margin="0,20,0,0"
                                    Height="46"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveButton_Click"
                                    Content="Зберегти"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                    CornerRadius="18"
                                    Background="{DynamicResource SecondaryCardBrush}"
                                    Padding="12">
                                    <Image x:Name="CountryViewImage"
                                       Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedCountryName}"/>
                                    <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           Text="Ось список місць, які вам точно потрібно відвідати в даній країні:"/>
                                    <TextBlock Margin="0,16,0,0"
                                           Style="{StaticResource SubtitleTextStyle}"
                                           Text="{Binding SelectedCountryShortInfo}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ItemsControl x:Name="PlacesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="300"
                                           ItemHeight="390"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280"
                                        Height="370"
                                        Margin="0,0,16,16"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="18"
                                        Padding="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="170"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border CornerRadius="14"
                                                Background="{DynamicResource SecondaryCardBrush}">
                                                <Image Source="{Binding PreViewImage}"
                                                   Stretch="UniformToFill"/>
                                            </Border>

                                            <TextBlock Grid.Row="1"
                                                   Margin="0,14,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Place}"/>
                                            <TextBlock Grid.Row="2"
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   Text="{Binding Category}"/>
                                            <TextBlock Grid.Row="3"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}"/>
                                            <CheckBox x:Name="CheckBox_Added"
                                                  Grid.Row="4"
                                                  IsChecked="{Binding IsAdded, Mode=TwoWay}"
                                                  Style="{StaticResource CheckBoxStyle}"
                                                  Content="Додати до подорожі"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Border>
</Window>
